diff --git a/pdfa11y.module b/pdfa11y.module
index 1e55266..cee7e65 100644
--- a/pdfa11y.module
+++ b/pdfa11y.module
@@ -15,6 +15,8 @@
 declare(strict_types=1);
 
 use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
+use Drupal\Core\Form\FormStateInterface;
+use Drupal\media\Entity\MediaType;
 use Drupal\media\MediaInterface;
 
 /**
@@ -57,3 +59,82 @@ function pdfa11y_media_update(MediaInterface $media): void {
 function pdfa11y_media_view(array &$build, MediaInterface $media, EntityViewDisplayInterface $display): void {
   \Drupal::service('pdfa11y.entity_hooks')->mediaView($build, $media, $display);
 }
+
+/**
+ * Implements hook_form_alter().
+ */
+function pdfa11y_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
+  $form_object = $form_state->getFormObject();
+  if (!$form_object || !method_exists($form_object, 'getEntity')) {
+    return;
+  }
+
+  $entity = $form_object->getEntity();
+  if (!$entity instanceof MediaInterface) {
+    return;
+  }
+
+  $media_type = MediaType::load($entity->bundle());
+  if (!$media_type) {
+    return;
+  }
+
+  $source = $entity->getSource();
+  $source_field = $source->getSourceFieldDefinition($media_type);
+  if (!$source_field) {
+    return;
+  }
+
+  $source_field_name = $source_field->getName();
+  if (!isset($form[$source_field_name]) || !is_array($form[$source_field_name])) {
+    return;
+  }
+
+  $messenger = \Drupal::messenger();
+  $warning_messages = $messenger->messagesByType('warning');
+  if (empty($warning_messages)) {
+    return;
+  }
+
+  $pdfa11y_messages = [];
+  $other_warnings = [];
+  foreach ($warning_messages as $message) {
+    $text = trim(strip_tags((string) $message));
+    if (str_contains($text, 'The uploaded PDF has accessibility issues')) {
+      $pdfa11y_messages[] = $message;
+    }
+    else {
+      $other_warnings[] = $message;
+    }
+  }
+
+  if (empty($pdfa11y_messages)) {
+    return;
+  }
+
+  // Remove warning messages from the global messages region and re-add any
+  // warnings that are unrelated to PDFa11y.
+  $messenger->deleteByType('warning');
+  foreach ($other_warnings as $message) {
+    $messenger->addWarning($message);
+  }
+
+  $target = &$form[$source_field_name];
+  if (isset($form[$source_field_name]['widget']) && is_array($form[$source_field_name]['widget'])) {
+    $target = &$form[$source_field_name]['widget'];
+  }
+
+  $target['pdfa11y_inline_warnings'] = [
+    '#type' => 'container',
+    '#attributes' => [
+      'class' => ['messages', 'messages--warning', 'pdfa11y-inline-warning'],
+      'role' => 'contentinfo',
+      'aria-label' => t('Warning message'),
+    ],
+    'message' => [
+      '#theme' => 'item_list',
+      '#items' => $pdfa11y_messages,
+    ],
+    '#weight' => 100,
+  ];
+}
diff --git a/src/Plugin/AccessibilityCheck/FigureAltTextCheck.php b/src/Plugin/AccessibilityCheck/FigureAltTextCheck.php
new file mode 100644
index 0000000..b69c322
--- /dev/null
+++ b/src/Plugin/AccessibilityCheck/FigureAltTextCheck.php
@@ -0,0 +1,238 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\pdfa11y\Plugin\AccessibilityCheck;
+
+use Drupal\Core\StringTranslation\TranslatableMarkup;
+use Drupal\pdfa11y\AccessibilityCheckBase;
+use Drupal\pdfa11y\AccessibilityCheckResult;
+use Drupal\pdfa11y\Attribute\AccessibilityCheck;
+use Smalot\PdfParser\Document;
+use Smalot\PdfParser\Element\Element;
+use Smalot\PdfParser\Element\ElementArray;
+use Smalot\PdfParser\Element\ElementMissing;
+use Smalot\PdfParser\Element\ElementString;
+
+/**
+ * Checks that figure elements include alternative text.
+ */
+#[AccessibilityCheck(
+  id: 'figure_alt_text',
+  label: new TranslatableMarkup('Figure ALT text'),
+  description: new TranslatableMarkup('Checks Figure elements in tagged PDFs and verifies they include ALT text.'),
+  category: 'structure',
+  weight: 30,
+)]
+class FigureAltTextCheck extends AccessibilityCheckBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  public function check(Document $document, string $fileUri): AccessibilityCheckResult {
+    $catalogs = $document->getObjectsByType('Catalog');
+    if (empty($catalogs)) {
+      return $this->fail(
+        (string) $this->t('Could not locate the document catalog to inspect figure ALT text.'),
+        AccessibilityCheckResult::SEVERITY_ERROR,
+      );
+    }
+
+    $catalog = reset($catalogs);
+    $structTreeRoot = $catalog->get('StructTreeRoot');
+    if ($structTreeRoot instanceof ElementMissing || $structTreeRoot === NULL) {
+      return $this->notApplicable(
+        (string) $this->t('Figure ALT text could not be evaluated because the document has no structure tree.'),
+      );
+    }
+
+    $roleMap = $this->extractRoleMap($structTreeRoot);
+    $figuresWithoutAlt = 0;
+    $totalFigures = 0;
+    $this->inspectNode($structTreeRoot, $roleMap, $totalFigures, $figuresWithoutAlt);
+
+    if ($totalFigures === 0) {
+      return $this->notApplicable(
+        (string) $this->t('No Figure elements were found in the structure tree.'),
+      );
+    }
+
+    if ($figuresWithoutAlt === 0) {
+      return $this->pass(
+        (string) $this->t('All @count Figure elements include ALT text.', ['@count' => (string) $totalFigures]),
+      );
+    }
+
+    return $this->fail(
+      (string) $this->t('@missing of @total Figure elements are missing ALT text.', [
+        '@missing' => (string) $figuresWithoutAlt,
+        '@total' => (string) $totalFigures,
+      ]),
+    );
+  }
+
+  /**
+   * Recursively inspects structure tree nodes for Figure elements.
+   *
+   * @param mixed $node
+   *   Current node.
+   * @param array<string, string> $roleMap
+   *   Role map used to normalize custom structure tags.
+   * @param int $totalFigures
+   *   Total Figure count.
+   * @param int $figuresWithoutAlt
+   *   Figure count missing ALT text.
+   */
+  protected function inspectNode(mixed $node, array $roleMap, int &$totalFigures, int &$figuresWithoutAlt): void {
+    if ($node instanceof ElementArray) {
+      $content = $node->getContent();
+      if (is_array($content)) {
+        foreach ($content as $child) {
+          $this->inspectNode($child, $roleMap, $totalFigures, $figuresWithoutAlt);
+        }
+      }
+      return;
+    }
+
+    if (is_array($node)) {
+      foreach ($node as $child) {
+        $this->inspectNode($child, $roleMap, $totalFigures, $figuresWithoutAlt);
+      }
+      return;
+    }
+
+    if (!is_object($node)) {
+      return;
+    }
+
+    if (method_exists($node, 'get')) {
+      $normalizedType = $this->normalizeStructureType((string) $node->get('S'), $roleMap);
+      if ($normalizedType === 'Figure') {
+        $totalFigures++;
+        if (!$this->hasAltText($node)) {
+          $figuresWithoutAlt++;
+        }
+      }
+
+      $children = $node->get('K');
+      if (!($children instanceof ElementMissing) && $children !== NULL) {
+        $this->inspectNode($children, $roleMap, $totalFigures, $figuresWithoutAlt);
+      }
+    }
+
+    if (method_exists($node, 'getDetails')) {
+      $details = $node->getDetails(FALSE);
+      if (is_array($details) && isset($details['K'])) {
+        $this->inspectNode($details['K'], $roleMap, $totalFigures, $figuresWithoutAlt);
+      }
+    }
+  }
+
+  /**
+   * Checks whether a structure element contains non-empty ALT text.
+   *
+   * @param object $node
+   *   Structure element object.
+   *
+   * @return bool
+   *   TRUE when ALT text exists and is non-empty.
+   */
+  protected function hasAltText(object $node): bool {
+    if (method_exists($node, 'get')) {
+      $alt = $node->get('Alt');
+      if ($alt instanceof ElementString) {
+        return trim((string) $alt) !== '';
+      }
+      if (!($alt instanceof ElementMissing) && trim((string) $alt) !== '') {
+        return TRUE;
+      }
+    }
+
+    if (method_exists($node, 'getDetails')) {
+      $details = $node->getDetails(FALSE);
+      if (is_array($details) && isset($details['Alt']) && trim((string) $details['Alt']) !== '') {
+        return TRUE;
+      }
+    }
+
+    return FALSE;
+  }
+
+  /**
+   * Extracts role mapping (custom tag -> standard tag) from structure tree.
+   *
+   * @param mixed $structTreeRoot
+   *   StructTreeRoot element.
+   *
+   * @return array<string, string>
+   *   Mapping of source role to normalized role.
+   */
+  protected function extractRoleMap(mixed $structTreeRoot): array {
+    if (!is_object($structTreeRoot) || !method_exists($structTreeRoot, 'get')) {
+      return [];
+    }
+
+    $roleMap = $structTreeRoot->get('RoleMap');
+    if ($roleMap instanceof ElementMissing || $roleMap === NULL || !method_exists($roleMap, 'getDetails')) {
+      return [];
+    }
+
+    $details = $roleMap->getDetails(FALSE);
+    if (!is_array($details)) {
+      return [];
+    }
+
+    $mapping = [];
+    foreach ($details as $from => $to) {
+      $mapping[(string) $from] = trim($this->elementToString($to));
+    }
+
+    return $mapping;
+  }
+
+  /**
+   * Resolves a structure type through role-map aliases.
+   *
+   * @param string $type
+   *   Raw structure type.
+   * @param array<string, string> $roleMap
+   *   Role map.
+   *
+   * @return string
+   *   Normalized structure type.
+   */
+  protected function normalizeStructureType(string $type, array $roleMap): string {
+    $resolved = trim($type);
+    if ($resolved === '') {
+      return '';
+    }
+
+    $seen = [];
+    while (isset($roleMap[$resolved]) && !isset($seen[$resolved])) {
+      $seen[$resolved] = TRUE;
+      $resolved = trim($roleMap[$resolved]);
+    }
+
+    return $resolved;
+  }
+
+  /**
+   * Converts parsed values to strings.
+   *
+   * @param mixed $value
+   *   Parsed value.
+   *
+   * @return string
+   *   Scalar string representation.
+   */
+  protected function elementToString(mixed $value): string {
+    if ($value instanceof Element) {
+      return (string) $value;
+    }
+    if (is_scalar($value)) {
+      return (string) $value;
+    }
+    return '';
+  }
+
+}
diff --git a/src/Plugin/AccessibilityCheck/HeadingStructureCheck.php b/src/Plugin/AccessibilityCheck/HeadingStructureCheck.php
new file mode 100644
index 0000000..6883950
--- /dev/null
+++ b/src/Plugin/AccessibilityCheck/HeadingStructureCheck.php
@@ -0,0 +1,388 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\pdfa11y\Plugin\AccessibilityCheck;
+
+use Drupal\Core\StringTranslation\TranslatableMarkup;
+use Drupal\pdfa11y\AccessibilityCheckBase;
+use Drupal\pdfa11y\AccessibilityCheckResult;
+use Drupal\pdfa11y\Attribute\AccessibilityCheck;
+use Smalot\PdfParser\Document;
+use Smalot\PdfParser\Element\Element;
+use Smalot\PdfParser\Element\ElementArray;
+use Smalot\PdfParser\Element\ElementMissing;
+
+/**
+ * Checks heading structure for common accessibility hierarchy issues.
+ */
+#[AccessibilityCheck(
+  id: 'heading_structure',
+  label: new TranslatableMarkup('Heading structure'),
+  description: new TranslatableMarkup('Checks heading order and reports skipped heading levels.'),
+  category: 'structure',
+  weight: 40,
+)]
+class HeadingStructureCheck extends AccessibilityCheckBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  public function check(Document $document, string $fileUri): AccessibilityCheckResult {
+    $catalogs = $document->getObjectsByType('Catalog');
+    if (empty($catalogs)) {
+      return $this->fail(
+        (string) $this->t('Could not locate the document catalog to inspect heading structure.'),
+        AccessibilityCheckResult::SEVERITY_ERROR,
+      );
+    }
+
+    $catalog = reset($catalogs);
+    $structTreeRoot = $catalog->get('StructTreeRoot');
+    if ($structTreeRoot instanceof ElementMissing || $structTreeRoot === NULL) {
+      return $this->notApplicable(
+        (string) $this->t('Heading structure could not be evaluated because the document has no structure tree.'),
+      );
+    }
+
+    $roleMap = $this->extractRoleMap($structTreeRoot);
+    $structuredHeadings = [];
+    $this->collectHeadings($structTreeRoot, $roleMap, $structuredHeadings);
+    $rawStreamHeadings = $this->extractHeadingsFromRawStreams($fileUri);
+    $headings = $this->mergeWithRawStreamHeadings($structuredHeadings, $rawStreamHeadings);
+
+    if (empty($headings)) {
+      return $this->fail(
+        (string) $this->t('The document contains no headings.'),
+      );
+    }
+
+    $leveledHeadings = array_values(array_filter($headings, static fn(int $level): bool => $level > 0));
+    if (empty($leveledHeadings)) {
+      return $this->pass(
+        (string) $this->t('Headings were found, but none are explicitly tagged as H1-H6.'),
+      );
+    }
+
+    $issues = [];
+    if ($leveledHeadings[0] !== 1) {
+      $issues[] = (string) $this->t('first heading is H@level (expected H1)', [
+        '@level' => (string) $leveledHeadings[0],
+      ]);
+    }
+
+    $h1Count = count(array_filter($leveledHeadings, static fn(int $level): bool => $level === 1));
+    if ($h1Count > 1) {
+      $issues[] = (string) $this->t('multiple H1 headings found (@count)', [
+        '@count' => (string) $h1Count,
+      ]);
+    }
+
+    $skips = [];
+    for ($i = 1; $i < count($leveledHeadings); $i++) {
+      $previous = $leveledHeadings[$i - 1];
+      $current = $leveledHeadings[$i];
+      if ($current > ($previous + 1)) {
+        $skips[] = 'H' . $previous . ' -> H' . $current;
+      }
+    }
+
+    if (!empty($skips)) {
+      $issues[] = (string) $this->t('out-of-order headings (skipped levels): @skips', [
+        '@skips' => implode(', ', $skips),
+      ]);
+    }
+
+    if ($this->hasRawOutOfOrderSignal($structuredHeadings, $rawStreamHeadings)) {
+      $issues[] = (string) $this->t('out-of-order headings detected in compressed structure tags');
+    }
+
+    if (!empty($issues)) {
+      return $this->fail(
+        (string) $this->t('Heading issues: @issues.', [
+          '@issues' => implode('; ', $issues),
+        ]),
+      );
+    }
+
+    return $this->pass(
+      (string) $this->t(
+        'Heading structure passed: @count headings analyzed, with no ordering issues.',
+        ['@count' => (string) count($headings)],
+      ),
+    );
+  }
+
+  /**
+   * Recursively collects heading levels from structure tree.
+   *
+   * @param mixed $node
+   *   Current node.
+   * @param array<string, string> $roleMap
+   *   Role map used to normalize custom structure tags.
+   * @param int[] $headings
+   *   Collected heading levels in discovered order.
+   */
+  protected function collectHeadings(mixed $node, array $roleMap, array &$headings): void {
+    if ($node instanceof ElementArray) {
+      $content = $node->getContent();
+      if (is_array($content)) {
+        foreach ($content as $child) {
+          $this->collectHeadings($child, $roleMap, $headings);
+        }
+      }
+      return;
+    }
+
+    if (is_array($node)) {
+      foreach ($node as $child) {
+        $this->collectHeadings($child, $roleMap, $headings);
+      }
+      return;
+    }
+
+    if (!is_object($node)) {
+      return;
+    }
+
+    if (method_exists($node, 'get')) {
+      $normalizedType = $this->normalizeStructureType((string) $node->get('S'), $roleMap);
+      $this->addHeadingLevel($normalizedType, $headings);
+
+      $children = $node->get('K');
+      if (!($children instanceof ElementMissing) && $children !== NULL) {
+        $this->collectHeadings($children, $roleMap, $headings);
+      }
+    }
+
+    if (method_exists($node, 'getDetails')) {
+      $details = $node->getDetails(FALSE);
+      if (is_array($details) && isset($details['K'])) {
+        $this->collectHeadings($details['K'], $roleMap, $headings);
+      }
+    }
+  }
+
+  /**
+   * Adds a heading level to the list when tag type is a heading.
+   *
+   * Uses level 0 for generic H tags with no explicit level.
+   *
+   * @param string $type
+   *   Normalized structure type.
+   * @param int[] $headings
+   *   Heading levels list.
+   */
+  protected function addHeadingLevel(string $type, array &$headings): void {
+    if (preg_match('/^H([1-6])$/', $type, $matches)) {
+      $headings[] = (int) $matches[1];
+    }
+    elseif ($type === 'H') {
+      $headings[] = 0;
+    }
+  }
+
+  /**
+   * Merges headings with a conservative raw-stream extractor fallback.
+   *
+   * Smalot can miss heading tags embedded in compressed object streams in some
+   * PDFs. We only trust raw-stream extraction when it clearly extends the same
+   * base heading order already found by the structured traversal.
+   *
+   * @param int[] $headings
+   *   Headings from structure traversal.
+   * @param string $fileUri
+   *   File URI/path.
+   *
+   * @return int[]
+   *   Merged headings.
+   */
+  protected function mergeWithRawStreamHeadings(array $headings, array $rawHeadings): array {
+    if (empty($rawHeadings)) {
+      return $headings;
+    }
+
+    if (empty($headings)) {
+      return $rawHeadings;
+    }
+
+    if (count($rawHeadings) <= count($headings)) {
+      return $headings;
+    }
+
+    $prefix = array_slice($rawHeadings, 0, count($headings));
+    if ($prefix === $headings) {
+      return $rawHeadings;
+    }
+
+    return $headings;
+  }
+
+  /**
+   * Detects strong out-of-order evidence from raw stream headings.
+   *
+   * Smalot can flatten heading levels in object streams. If raw stream parsing
+   * reveals deeper heading levels than the structured traversal ever sees, we
+   * treat that as additional out-of-order evidence.
+   *
+   * @param int[] $structuredHeadings
+   *   Headings from structured traversal.
+   * @param int[] $rawHeadings
+   *   Headings from raw stream scan.
+   *
+   * @return bool
+   *   TRUE when raw stream data shows likely hidden ordering problems.
+   */
+  protected function hasRawOutOfOrderSignal(array $structuredHeadings, array $rawHeadings): bool {
+    if (empty($structuredHeadings) || empty($rawHeadings)) {
+      return FALSE;
+    }
+
+    $structuredLevels = array_values(array_filter($structuredHeadings, static fn(int $level): bool => $level > 0));
+    $rawLevels = array_values(array_filter($rawHeadings, static fn(int $level): bool => $level > 0));
+    if (empty($structuredLevels) || empty($rawLevels)) {
+      return FALSE;
+    }
+
+    return max($rawLevels) > max($structuredLevels);
+  }
+
+  /**
+   * Extracts heading tags from raw/decompressed PDF streams.
+   *
+   * @param string $fileUri
+   *   File URI/path.
+   *
+   * @return int[]
+   *   Heading levels in discovered order.
+   */
+  protected function extractHeadingsFromRawStreams(string $fileUri): array {
+    $content = @file_get_contents($fileUri);
+    if ($content === FALSE || $content === '') {
+      return [];
+    }
+
+    $matches = [];
+    preg_match_all('/<<(.*?)>>\\s*stream\\s*(.*?)\\s*endstream/s', $content, $matches, PREG_SET_ORDER);
+    if (empty($matches)) {
+      return [];
+    }
+
+    $headings = [];
+    foreach ($matches as $match) {
+      $dict = $match[1] ?? '';
+      $stream = $match[2] ?? '';
+      if ($stream === '') {
+        continue;
+      }
+
+      $data = $stream;
+      if (strpos($dict, '/FlateDecode') !== FALSE) {
+        $decoded = @gzuncompress($stream);
+        if ($decoded === FALSE) {
+          $decoded = @gzinflate($stream);
+        }
+        if ($decoded === FALSE) {
+          $decoded = @gzdecode($stream);
+        }
+        if ($decoded !== FALSE && is_string($decoded) && $decoded !== '') {
+          $data = $decoded;
+        }
+      }
+
+      if (preg_match_all('/\\/S\\s*\\/(H[1-6]|Title|H)\\b/', $data, $tagMatches) && !empty($tagMatches[1])) {
+        foreach ($tagMatches[1] as $tag) {
+          if ($tag === 'Title') {
+            $headings[] = 1;
+          }
+          elseif ($tag === 'H') {
+            $headings[] = 0;
+          }
+          elseif (preg_match('/^H([1-6])$/', $tag, $level)) {
+            $headings[] = (int) $level[1];
+          }
+        }
+      }
+    }
+
+    return $headings;
+  }
+
+  /**
+   * Extracts role mapping (custom tag -> standard tag) from structure tree.
+   *
+   * @param mixed $structTreeRoot
+   *   StructTreeRoot element.
+   *
+   * @return array<string, string>
+   *   Mapping of source role to normalized role.
+   */
+  protected function extractRoleMap(mixed $structTreeRoot): array {
+    if (!is_object($structTreeRoot) || !method_exists($structTreeRoot, 'get')) {
+      return [];
+    }
+
+    $roleMap = $structTreeRoot->get('RoleMap');
+    if ($roleMap instanceof ElementMissing || $roleMap === NULL || !method_exists($roleMap, 'getDetails')) {
+      return [];
+    }
+
+    $details = $roleMap->getDetails(FALSE);
+    if (!is_array($details)) {
+      return [];
+    }
+
+    $mapping = [];
+    foreach ($details as $from => $to) {
+      $mapping[(string) $from] = trim($this->elementToString($to));
+    }
+
+    return $mapping;
+  }
+
+  /**
+   * Resolves a structure type through role-map aliases.
+   *
+   * @param string $type
+   *   Raw structure type.
+   * @param array<string, string> $roleMap
+   *   Role map.
+   *
+   * @return string
+   *   Normalized structure type.
+   */
+  protected function normalizeStructureType(string $type, array $roleMap): string {
+    $resolved = trim($type);
+    if ($resolved === '') {
+      return '';
+    }
+
+    $seen = [];
+    while (isset($roleMap[$resolved]) && !isset($seen[$resolved])) {
+      $seen[$resolved] = TRUE;
+      $resolved = trim($roleMap[$resolved]);
+    }
+
+    return $resolved;
+  }
+
+  /**
+   * Converts parsed values to strings.
+   *
+   * @param mixed $value
+   *   Parsed value.
+   *
+   * @return string
+   *   Scalar string representation.
+   */
+  protected function elementToString(mixed $value): string {
+    if ($value instanceof Element) {
+      return (string) $value;
+    }
+    if (is_scalar($value)) {
+      return (string) $value;
+    }
+    return '';
+  }
+
+}
diff --git a/tests/src/Functional/Pdfa11yWarningPlacementTest.php b/tests/src/Functional/Pdfa11yWarningPlacementTest.php
