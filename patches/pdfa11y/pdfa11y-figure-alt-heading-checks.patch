+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\pdfa11y\Functional;
+
+use Drupal\field\Entity\FieldConfig;
+use Drupal\field\Entity\FieldStorageConfig;
+use Drupal\media\Entity\MediaType;
+use Drupal\Tests\BrowserTestBase;
+use Drupal\Core\Entity\Display\EntityFormDisplay;
+
+/**
+ * Tests inline placement of PDFa11y upload warnings on media forms.
+ *
+ * @group pdfa11y
+ * @runTestsInSeparateProcesses
+ */
+class Pdfa11yWarningPlacementTest extends BrowserTestBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected static $modules = [
+    'system',
+    'user',
+    'field',
+    'file',
+    'media',
+    'pdfa11y',
+  ];
+
+  /**
+   * {@inheritdoc}
+   */
+  protected $defaultTheme = 'stark';
+
+  /**
+   * Sets up a document media type with file source field.
+   */
+  protected function setUp(): void {
+    parent::setUp();
+
+    MediaType::create([
+      'id' => 'document',
+      'label' => 'Document',
+      'source' => 'file',
+      'source_configuration' => [
+        'source_field' => 'field_media_file',
+      ],
+    ])->save();
+
+    FieldStorageConfig::create([
+      'field_name' => 'field_media_file',
+      'entity_type' => 'media',
+      'type' => 'file',
+      'cardinality' => 1,
+      'settings' => [
+        'uri_scheme' => 'public',
+      ],
+    ])->save();
+
+    FieldConfig::create([
+      'field_name' => 'field_media_file',
+      'entity_type' => 'media',
+      'bundle' => 'document',
+      'label' => 'File',
+      'settings' => [
+        'file_extensions' => 'pdf',
+      ],
+      'required' => TRUE,
+    ])->save();
+
+    EntityFormDisplay::create([
+      'targetEntityType' => 'media',
+      'bundle' => 'document',
+      'mode' => 'default',
+      'status' => TRUE,
+    ])->setComponent('field_media_file', [
+      'type' => 'file_generic',
+      'weight' => 5,
+      'settings' => [],
+    ])->save();
+  }
+
+  /**
+   * Tests that PDFa11y warning is rendered inline in file field widget.
+   */
+  public function testWarningAppearsInlineUnderFileWidget(): void {
+    $user = $this->createUser([
+      'access content',
+      'create document media',
+    ]);
+    $this->drupalLogin($user);
+
+    // Seed a warning message similar to Pdfa11yConstraintValidator output.
+    \Drupal::messenger()->addWarning('The uploaded PDF has accessibility issues: Example warning.');
+    \Drupal::messenger()->addWarning('Another unrelated warning.');
+
+    $this->drupalGet('media/add/document');
+
+    $this->assertSession()->pageTextContains('The uploaded PDF has accessibility issues: Example warning.');
+    $this->assertSession()->elementExists('css', '.pdfa11y-inline-warning');
+    $this->assertSession()->elementExists('css', '#edit-field-media-file-wrapper .pdfa11y-inline-warning');
+    // Unrelated warning should stay in global messages.
+    $this->assertSession()->pageTextContains('Another unrelated warning.');
+  }
+
+}
