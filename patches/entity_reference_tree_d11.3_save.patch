       $("#" + fieldEditID).val(selectedEntites).trigger('change');
     }
   };
+  // Capture-phase click handler for the modal "Save" buttons (both the hidden
+  // original submit input and the visible dialog button). This runs before any
+  // Drupal.ajax handlers that might otherwise submit the form and redirect.
+  document.addEventListener('click', function (event) {
+    var target = event.target;
+    if (!(target instanceof HTMLElement)) {
+      return;
+    }
+
+    if (!target.classList.contains('entity-reference-tree-save')) {
+      return;
+    }
+
+    var form = target.closest('form');
+    if (!form || !form.id || form.id.indexOf('entity-reference-tree-search-form') !== 0) {
+      return;
+    }
+
+    event.preventDefault();
+    event.stopImmediatePropagation();
+    event.stopPropagation();
+
+    var $ = window.jQuery || window.$;
+    if (!$) {
+      return;
+    }
+
+    var fieldEditID = $('#entity-reference-tree-widget-field').val();
+    var selectedEntities = $('#entity-reference-tree-selected-node').val();
+
+    if (fieldEditID) {
+      $.fn.entitySearchDialogAjaxCallback(fieldEditID, selectedEntities);
+    }
+
+    // Close the dialog hosting the tree widget.
+    try {
+      var $dialogContent = $(target).closest('.ui-dialog-content');
+      if (!$dialogContent.length) {
+        $dialogContent = $('#entity-reference-tree-modal');
+      }
+      if (!$dialogContent.length) {
+        $dialogContent = $('.ui-dialog-content:visible').last();
+      }
+      if ($dialogContent.length) {
+        $dialogContent.dialog('close');
+      }
+    }
+    catch (err) {
+      // Swallow errors; worst case the dialog stays open.
+    }
+  }, true);
 })(jQuery);
