+/**
+ * @file
+ * Decorative image widget alignment styles.
+ *
+ * Scoped to Claro image widgets only. Entity embed dialogs use default
+ * form styling and do not need these overrides.
+ */
+
+.form-managed-file__meta-items .decorative-image-widget__decorative.form-type--boolean {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  column-gap: var(--space-xs);
+  clear: none;
+  margin-inline-start: 0;
+}
+
+.form-managed-file__meta-items .decorative-image-widget__decorative .description,
+.form-managed-file__meta-items .decorative-image-widget__decorative .mass-description {
+  flex: 0 0 100%;
+  margin-inline-start: 0;
+}
+
+/* Reset Claro horizontal checkbox offsets; flex handles vertical alignment. */
+.form-managed-file__meta-items .decorative-image-widget__decorative.form-type--boolean .form-boolean {
+  position: static;
+  float: none;
+  margin-inline: 0;
+  transform: none;
+  flex: 0 0 auto;
+}
