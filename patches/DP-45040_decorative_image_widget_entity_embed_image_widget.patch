diff --color -uNr a/src/Plugin/entity_embed/EntityEmbedDisplay/DecorativeImageFieldFormatter.php b/src/Plugin/entity_embed/EntityEmbedDisplay/DecorativeImageFieldFormatter.php
--- a/src/Plugin/entity_embed/EntityEmbedDisplay/DecorativeImageFieldFormatter.php	1970-01-01 04:00:00
+++ b/src/Plugin/entity_embed/EntityEmbedDisplay/DecorativeImageFieldFormatter.php	2026-06-23 12:08:32
@@ -0,0 +1,125 @@
+<?php
+
+namespace Drupal\decorative_image_widget\Plugin\entity_embed\EntityEmbedDisplay;
+
+use Drupal\Core\Form\FormStateInterface;
+use Drupal\entity_embed\Plugin\entity_embed\EntityEmbedDisplay\ImageFieldFormatter;
+
+/**
+ * Entity embed image display with decorative checkbox support.
+ *
+ * This subclass adds the Decorative checkbox and validation to the entity
+ * embed image dialog, while reusing the core ImageFieldFormatter behavior.
+ */
+class DecorativeImageFieldFormatter extends ImageFieldFormatter {
+
+  /**
+   * Form value parents for the decorative setting in the embed dialog.
+   */
+  protected const DECORATIVE_SETTING_PARENTS = [
+    'attributes',
+    'data-entity-embed-display-settings',
+    'decorative',
+  ];
+
+  /**
+   * {@inheritdoc}
+   */
+  public function defaultConfiguration() {
+    return parent::defaultConfiguration() + [
+      'decorative' => FALSE,
+    ];
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function buildConfigurationForm(array $form, FormStateInterface $form_state) {
+    $form = parent::buildConfigurationForm($form, $form_state);
+
+    if (empty($form['alt']) || !is_array($form['alt'])) {
+      return $form;
+    }
+
+    $alt_weight = $form['alt']['#weight'] ?? 0;
+
+    $form['alt']['#required'] = FALSE;
+    $form['alt']['#description'] = $this->t("Alternative Text is read by screen readers and should be a concise description of the image's purpose. If the image is purely decorative, leave this field blank and check the \"decorative\" checkbox below.");
+    $form['alt']['#attributes']['class'][] = 'alt-textfield';
+    $form['alt']['#element_validate'][] = [static::class, 'validateAltOrDecorative'];
+
+    $decorative = [
+      '#type' => 'checkbox',
+      '#title' => $this->t('Decorative'),
+      '#description' => $this->t('This image is <a href=":url" target="_blank">decorative</a> and should be hidden from screen readers.', [
+        ':url' => 'https://www.w3.org/WAI/tutorials/images/decorative/',
+      ]),
+      '#description_display' => 'after',
+      '#default_value' => $this->getDecorativeDefaultValue(),
+      '#weight' => $alt_weight + 0.1,
+      '#attributes' => [
+        'class' => ['decorative-checkbox'],
+      ],
+    ];
+
+    // Place decorative directly below alt and before title.
+    if (isset($form['title']) && is_array($form['title'])) {
+      $title = $form['title'];
+      unset($form['title']);
+      $form['decorative'] = $decorative;
+      $title['#weight'] = $alt_weight + 1;
+      $form['title'] = $title;
+    }
+    else {
+      $form['decorative'] = $decorative;
+    }
+
+    try {
+      $library_discovery = \Drupal::service('library.discovery');
+      if ($library_discovery->getLibraryByName('decorative_image_widget', 'decorative_image_widget')) {
+        $form['#attached']['library'][] = 'decorative_image_widget/decorative_image_widget';
+      }
+    }
+    catch (\Exception $e) {
+      // If the library is not available, we still keep the validation behavior.
+    }
+
+    return $form;
+  }
+
+  /**
+   * Determines whether the decorative checkbox should be checked by default.
+   */
+  protected function getDecorativeDefaultValue(): bool {
+    return (bool) $this->getConfigurationValue('decorative', FALSE);
+  }
+
+  /**
+   * Validation callback requiring either alt text or decorative checkbox.
+   */
+  public static function validateAltOrDecorative(array $element, FormStateInterface $form_state, array &$complete_form) {
+    $parents = $element['#parents'];
+    $alt_value = trim((string) ($form_state->getValue($parents) ?? ''));
+
+    if ($alt_value === '""') {
+      $alt_value = '';
+      $form_state->setValue($parents, '');
+    }
+
+    $decorative_checked = (bool) $form_state->getValue(static::DECORATIVE_SETTING_PARENTS);
+
+    if ($decorative_checked) {
+      $form_state->setValue($parents, '');
+      $form_state->setValue(static::DECORATIVE_SETTING_PARENTS, 1);
+      $alt_value = '';
+    }
+    else {
+      $form_state->unsetValue(static::DECORATIVE_SETTING_PARENTS);
+    }
+
+    if ($alt_value === '' && !$decorative_checked) {
+      $form_state->setError($element, t('You must provide alternative text or indicate the image is decorative.'));
+    }
+  }
+
+}
diff --color -uNr a/templates/file-managed-file--decorative.html.twig b/templates/file-managed-file--decorative.html.twig
--- a/templates/file-managed-file--decorative.html.twig	1970-01-01 04:00:00
+++ b/templates/file-managed-file--decorative.html.twig	2026-06-23 12:08:32
@@ -0,0 +1,55 @@
+{#
+/**
+ * @file
+ * Theme override to display a file form widget with decorative checkbox.
+ *
+ * Renders the decorative checkbox inside meta-items so it aligns with alt.
+ *
+ * @see claro/templates/content-edit/file-managed-file.html.twig
+ */
+#}
+{%
+  set classes = [
+    'js-form-managed-file',
+    'form-managed-file',
+    multiple ? 'is-multiple' : 'is-single',
+    upload ? 'has-upload' : 'no-upload',
+    has_value ? 'has-value' : 'no-value',
+    has_meta ? 'has-meta' : 'no-meta',
+  ]
+%}
+<div{{ attributes.addClass(classes).removeClass('clearfix') }}>
+  <div class="form-managed-file__main">
+    {{ main_items.filename }}
+    {{ main_items|without('filename') }}
+  </div>
+
+  {% if has_meta or data.preview %}
+  <div class="form-managed-file__meta-wrapper">
+    <div class="form-managed-file__meta">
+      {% if data.preview %}
+        <div class="form-managed-file__image-preview image-preview">
+          <div class="image-preview__img-wrapper">
+            {{ data.preview }}
+          </div>
+        </div>
+      {% endif %}
+
+      {% if data.description or display or data.alt or data.title or data.decorative %}
+        <div class="form-managed-file__meta-items">
+          {{ data.description }}
+          {% if display %}
+            {{ data.display }}
+          {% endif %}
+          {{ data.alt }}
+          {{ data.decorative }}
+          {{ data.title }}
+        </div>
+      {% endif %}
+    </div>
+  </div>
+  {% endif %}
+
+  {# Every third-party addition will be rendered here. #}
+  {{ data|without('preview', 'alt', 'title', 'description', 'display', 'decorative') }}
+</div>
