     }
     elseif (preg_match('/^stream: (.*) FOUND$/', $response, $matches)) {
       $this->_virus_name = $matches[1];
-      $result = Scanner::FILE_IS_INFECTED;
+      // ClamAV reports scan-limit overruns through the same FOUND channel
+      // as real virus hits (e.g. "Heuristics.Limits.Exceeded.MaxScanSize").
+      // Treat those as "could not fully scan" rather than infected to avoid
+      // false positives on large/complex but clean files.
+      $result = str_starts_with($this->_virus_name, 'Heuristics.Limits.Exceeded.')
