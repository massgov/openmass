diff --git a/src/Scanner/Executable.php b/src/Scanner/Executable.php
--- a/src/Scanner/Executable.php
+++ b/src/Scanner/Executable.php
@@ -73,6 +73,13 @@ class Executable implements ScannerInterface {

       case 1:
         $this->setVirusName($filename);
+        // ClamAV reports scan-limit overruns through the same FOUND channel
+        // as real virus hits (e.g. "Heuristics.Limits.Exceeded.MaxScanSize").
+        // Treat those as "could not fully scan" rather than infected to avoid
+        // false positives on large/complex but clean files.
+        if (str_starts_with($this->_virus_name, 'Heuristics.Limits.Exceeded.')) {
+          return Scanner::FILE_EXCEEDS_SCAN_LIMITS;
+        }
         return Scanner::FILE_IS_INFECTED;

       default:
