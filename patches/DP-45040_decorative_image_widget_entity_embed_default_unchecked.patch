+/**
+ * Implements hook_entity_embed_display_plugins_alter().
+ */
+function decorative_image_widget_entity_embed_display_plugins_alter(array &$definitions) {
+  foreach ($definitions as &$definition) {
+    if (!empty($definition['class']) && $definition['class'] === 'Drupal\entity_embed\Plugin\entity_embed\EntityEmbedDisplay\ImageFieldFormatter') {
+      $definition['class'] = \Drupal\decorative_image_widget\Plugin\entity_embed\EntityEmbedDisplay\DecorativeImageFieldFormatter::class;
+    }
+  }
+}
diff --git a/js/decorative-image-widget.js b/js/decorative-image-widget.js
