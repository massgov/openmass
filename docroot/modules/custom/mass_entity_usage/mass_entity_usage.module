<?php

/**
 * @file
 * Contains mass_entity_usage.module.
 */

use Drupal\mass_entity_usage\UsageTrackingBlocker;

/**
 * Implements hook_entity_usage_block_tracking().
 */
function mass_entity_usage_entity_usage_block_tracking($target_id, $target_type, $source_id, $source_type, $source_langcode, $source_vid, $method, $field_name, $count) {
  // Block tracking of entities with a node source that is unpublished or trash.
  return !_mass_entity_usage_tracking_check($source_type, $source_id, $source_vid);
}

/**
 * Find an id/revision_id record in the default field data table.
 *
 * @param string $entity_type
 *   The entity type.
 * @param int $id
 *   The entity id.
 * @param int $vid
 *   The entity revision id.
 *
 * @return bool
 *   If true, the content should be tracked. If false, do not track.
 */
function _mass_entity_usage_tracking_check($entity_type, $id, $vid) {
  $tracking_blocker = new UsageTrackingBlocker(\Drupal::database(), \Drupal::service('entity_type.manager'));
  return $tracking_blocker->check($entity_type, $vid);
}

/**
 * Implements hook_queue_info_alter().
 */
function mass_entity_usage_queue_info_alter(&$queues) {
  // Removes entity usage queues from processing when cron runs.
  if (isset($queues['entity_usage_regenerate_queue'])) {
    unset($queues['entity_usage_regenerate_queue']['cron']);
  }
  if (isset($queues['entity_usage_tracker'])) {
    unset($queues['entity_usage_tracker']['cron']);
  }
}

/**
 * Implements hook_entity_usage_queue_tracking_should_remove_usage().
 *
 * When a node is in unpublished or trash moderation state, remove all
 * entity_usage records for that node and for its paragraphs. The queue worker
 * deletes the node's usage; we delete usage where a paragraph on this node is
 * the source. No usage is kept when the source has no published version (the
 * default revision is unpublished).
 *
 * @see \Drupal\entity_usage_queue_tracking\Plugin\QueueWorker\EntityUsageTracker::processItem()
 */
function mass_entity_usage_entity_usage_queue_tracking_should_remove_usage($entity) {
  if ($entity->getEntityTypeId() !== 'node') {
    return FALSE;
  }

  _mass_entity_usage_delete_stale_paragraph_usage($entity);

  $content_moderation_state = \Drupal\content_moderation\Entity\ContentModerationState::loadFromModeratedEntity($entity);
  if (!$content_moderation_state instanceof \Drupal\content_moderation\Entity\ContentModerationStateInterface
    || $content_moderation_state->get('moderation_state')->isEmpty()) {
    return FALSE;
  }

  $state = $content_moderation_state->get('moderation_state')->value;
  $remove_states = [
    \Drupal\mass_content_moderation\MassModeration::UNPUBLISHED,
    \Drupal\mass_content_moderation\MassModeration::TRASH,
  ];
  if (!in_array($state, $remove_states, TRUE)) {
    return FALSE;
  }

  $usage = \Drupal::service('entity_usage.usage');
  foreach (_mass_entity_usage_get_paragraph_ids_from_node($entity) as $paragraph_id) {
    $usage->deleteBySourceEntity($paragraph_id, 'paragraph');
  }
  \Drupal::service('cache_tags.invalidator')->invalidateTags(['config:views.view.report_orphaned_documents']);
  return TRUE;
}

/**
 * Collects paragraph IDs referenced by a node (entity_reference_revisions).
 *
 * @param \Drupal\Core\Entity\EntityInterface $node
 *   The node entity.
 *
 * @return int[]
 *   Unique paragraph entity IDs (including nested child paragraphs).
 */
function _mass_entity_usage_get_paragraph_ids_from_node($node) {
  $root_ids = [];
  foreach ($node->getFieldDefinitions() as $name => $definition) {
    if ($definition->getType() !== 'entity_reference_revisions') {
      continue;
    }
    if ($definition->getSetting('target_type') !== 'paragraph') {
      continue;
    }
    foreach ($node->get($name) as $item) {
      if ($item->target_id) {
        $root_ids[$item->target_id] = TRUE;
      }
    }
  }

  if (!$root_ids) {
    return [];
  }

  return _mass_entity_usage_get_nested_paragraph_ids(array_keys($root_ids));
}

/**
 * Expands a list of paragraph IDs to include all nested child paragraphs.
 *
 * This walks paragraph -> paragraph references (entity_reference_revisions with
 * target_type = 'paragraph') starting from the given IDs.
 *
 * @param int[] $paragraph_ids
 *   Root paragraph entity IDs.
 *
 * @return int[]
 *   All unique paragraph IDs reachable from the roots (including roots).
 */
function _mass_entity_usage_get_nested_paragraph_ids(array $paragraph_ids) {
  $storage = \Drupal::entityTypeManager()->getStorage('paragraph');
  $seen = [];
  $queue = $paragraph_ids;

  while ($queue) {
    $id = array_pop($queue);
    if (isset($seen[$id])) {
      continue;
    }
    $seen[$id] = TRUE;

    /** @var \Drupal\paragraphs\Entity\ParagraphInterface|null $paragraph */
    $paragraph = $storage->load($id);
    if (!$paragraph) {
      continue;
    }

    foreach ($paragraph->getFieldDefinitions() as $name => $definition) {
      if ($definition->getType() !== 'entity_reference_revisions') {
        continue;
      }
      if ($definition->getSetting('target_type') !== 'paragraph') {
        continue;
      }
      foreach ($paragraph->get($name) as $item) {
        if ($item->target_id && !isset($seen[$item->target_id])) {
          $queue[] = $item->target_id;
        }
      }
    }
  }

  return array_keys($seen);
}

/**
 * Deletes paragraph-source usage rows no longer reachable from a node.
 *
 * When a node revision replaces or removes a paragraph tree, older paragraph
 * entities can remain in storage long enough for their entity_usage rows to
 * persist. Compare all paragraph trees currently parented to the node against
 * the node's active paragraph tree and delete usage rows for detached
 * paragraphs.
 *
 * @param \Drupal\Core\Entity\EntityInterface $node
 *   The node currently being processed by the usage tracker queue.
 */
function _mass_entity_usage_delete_stale_paragraph_usage($node) {
  // Cheap guard: collect the node's current root paragraph ids straight from
  // the field values (no entity loads), and the root paragraphs still parented
  // to this node in storage (one query). A paragraph has a single parent, so a
  // root no longer referenced by the current revision means its whole subtree
  // is detached. If no root is detached there is nothing stale and we skip the
  // expensive tree walk entirely.
  $current_root_ids = [];
  foreach ($node->getFieldDefinitions() as $name => $definition) {
    if ($definition->getType() !== 'entity_reference_revisions') {
      continue;
    }
    if ($definition->getSetting('target_type') !== 'paragraph') {
      continue;
    }
    foreach ($node->get($name) as $item) {
      if ($item->target_id) {
        $current_root_ids[(int) $item->target_id] = TRUE;
      }
    }
  }

  $db_root_ids = \Drupal::database()
    ->select('paragraphs_item_field_data', 'pifd')
    ->fields('pifd', ['id'])
    ->condition('parent_type', 'node')
    ->condition('parent_id', $node->id())
    ->distinct()
    ->execute()
    ->fetchCol();

  $detached_roots = array_diff(array_map('intval', $db_root_ids), array_keys($current_root_ids));
  if (!$detached_roots) {
    return;
  }

  // Expand the detached subtrees via the storage table (parent_id back-refs)
  // instead of loading every paragraph entity, then delete their usage.
  $database = \Drupal::database();
  $stale_ids = [];
  $frontier = array_values($detached_roots);
  while ($frontier) {
    foreach ($frontier as $id) {
      $stale_ids[$id] = TRUE;
    }
    $children = $database->select('paragraphs_item_field_data', 'pifd')
      ->fields('pifd', ['id'])
      ->condition('parent_type', 'paragraph')
      ->condition('parent_id', $frontier, 'IN')
      ->distinct()
      ->execute()
      ->fetchCol();
    $frontier = array_diff(array_map('intval', $children), array_keys($stale_ids));
  }

  $usage = \Drupal::service('entity_usage.usage');
  foreach (array_keys($stale_ids) as $paragraph_id) {
    $usage->deleteBySourceEntity((int) $paragraph_id, 'paragraph');
  }
}
