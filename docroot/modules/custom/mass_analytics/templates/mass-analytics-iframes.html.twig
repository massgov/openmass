{#
/**
 * @file
 * Render the Power BI report in a short iframe so the "Sign in" button
 * stays visible above the fold. After the auth redirect chain stabilises
 * (a 4 s silence between cross-origin iframe load events), the iframe
 * auto-expands to full size. A manual Expand/Collapse toggle is always
 * available and disables the auto-expand once used.
 */
#}
<div class="mass-analytics-launcher" style="padding:1rem 0;">
  {% if node_title %}
    <h2 style="margin:0 0 .5rem 0;">Analytics dashboard: {{ node_title }}</h2>
  {% endif %}
  <p style="margin:0 0 1rem 0;color:#555;">
    Sign in to Power BI in the frame below. The dashboard will expand automatically once it loads.
  </p>

  <iframe
    id="mass-analytics-iframe"
    width="100%"
    height="220"
    seamless
    frameBorder="0"
    src="{{ config }}"
    style="border:1px solid #ccc;display:block;transition:height .3s ease;"></iframe>

  <p style="margin:1rem 0 0 0;display:flex;gap:1rem;align-items:center;">
    <button
      type="button"
      id="mass-analytics-expand-btn"
      data-collapsed-height="220"
      data-expanded-height="{{ iframe_height }}"
      aria-expanded="false"
      style="padding:.6rem 1.2rem;background:#14558f;color:#fff;border:0;border-radius:4px;cursor:pointer;font-weight:600;">
      Expand to full size
    </button>
    <a href="{{ config }}" target="_blank" rel="noopener" style="color:#14558f;">
      Or open the report in a new tab
    </a>
  </p>
</div>

<script>
(function () {
  var iframe = document.getElementById('mass-analytics-iframe');
  var btn = document.getElementById('mass-analytics-expand-btn');
  if (!iframe || !btn) return;

  var COLLAPSED = parseInt(btn.dataset.collapsedHeight, 10);
  var EXPANDED = parseInt(btn.dataset.expandedHeight, 10);
  var SILENCE_MS = 4000;
  var FALLBACK_MS = 30000;

  var silenceTimer = null;
  var fallbackTimer = null;
  var userTookOver = false;

  function applyExpanded() {
    iframe.height = EXPANDED;
    btn.setAttribute('aria-expanded', 'true');
    btn.textContent = 'Collapse';
  }
  function applyCollapsed() {
    iframe.height = COLLAPSED;
    btn.setAttribute('aria-expanded', 'false');
    btn.textContent = 'Expand to full size';
  }
  function autoExpand() {
    if (userTookOver) return;
    if (btn.getAttribute('aria-expanded') === 'true') return;
    applyExpanded();
  }

  // Cross-origin iframe content is unreadable, so we infer "auth chain done"
  // from the absence of further load events for SILENCE_MS.
  iframe.addEventListener('load', function () {
    clearTimeout(silenceTimer);
    silenceTimer = setTimeout(autoExpand, SILENCE_MS);
  });
  fallbackTimer = setTimeout(autoExpand, FALLBACK_MS);

  btn.addEventListener('click', function () {
    userTookOver = true;
    clearTimeout(silenceTimer);
    clearTimeout(fallbackTimer);
    if (btn.getAttribute('aria-expanded') === 'true') {
      applyCollapsed();
    } else {
      applyExpanded();
    }
  });
})();
</script>
