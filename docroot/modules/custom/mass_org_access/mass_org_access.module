<?php

declare(strict_types=1);

use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_query_alter().
 */
function mass_org_access_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  if ($view->id() !== 'rpt_permission_group_audit_nodes' || !$query instanceof Sql) {
    return;
  }

  $connection = $query->getConnection();
  $node_revision_alias = $query->ensureTable('node_field_revision');

  // Show only rows where the author and node revision share no Permission
  // Group terms at all.
  $shared_permission_group = $connection->select('user__field_user_org', 'uo');
  $shared_permission_group->addExpression('1');
  $shared_permission_group->innerJoin(
    'node_revision__field_content_organization',
    'nco',
    'nco.field_content_organization_target_id = uo.field_user_org_target_id'
  );
  $shared_permission_group->condition('uo.deleted', 0);
  $shared_permission_group->condition('nco.deleted', 0);
  $shared_permission_group->where("uo.entity_id = {$node_revision_alias}.uid");
  $shared_permission_group->where("nco.revision_id = {$node_revision_alias}.vid");
  $shared_permission_group->where("nco.langcode = {$node_revision_alias}.langcode");

  $query->addWhere(0, $connection->condition('AND')->notExists($shared_permission_group));
}
